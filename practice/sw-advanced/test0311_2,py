def binary_search_while(target):
    left = 0                # 검색 시작점
    right = len(arr) - 1    # 검색 끝점

    while left <= right:    # 교차가 되는 순간이 탐색 못한 순간
        mid = (left + right) // 2


        # 정답을 찾으면 종료
        if arr[mid] == target:
            return mid
        
        # arr[mid]가 target보다 큰 경우 (target이 왼쪽에 위치)
        # - 왼쪽을 탐색
        if target < arr[mid]:
            right = mid - 1
        # arr[mid]가 target보다 작은 경우 (target이 오른쪽에 위치)
        # - 오른쪽을 탐색
        else:
            left = mid + 1

    return - 1

